# Discord Token (dari Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# OpenAI-compatible endpoint
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=MiniMax-M2.7-highspeed
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# (Opsional/Fallback) Channel sekarang dikelola via command !ai setup / /setup
ALLOWED_CHANNELS=
ADMIN_IDS=your_discord_user_id_here

# Database configuration (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=discord_bot_ai

# === Built-in Tools ===
SEARCH_PROVIDER=duckduckgo          # duckduckgo | brave | serpapi | aikei
BRAVE_SEARCH_API_KEY=
SERPAPI_KEY=
AIKEI_SEARCH_API_KEY=

PLAYWRIGHT_BROWSERS_PATH=/home/container/.cache/ms-playwright
PLAYWRIGHT_ENABLED=false

RATE_LIMIT_WEB_SEARCH=10
RATE_LIMIT_FETCH_URL=20
RATE_LIMIT_NAVIGATE_WEB=5
RATE_LIMIT_DOWNLOAD_FILE=5
RATE_LIMIT_RUN_CODE=10
RATE_LIMIT_HTTP_REQUEST=15

DISABLED_TOOLS_GLOBAL=

# === Agent Loop ===
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_MS=180000

TMP_DIR=/home/container/tmp
WORKSPACE_DIR=/home/container/workspace
SANDBOX_DIR=/home/container/sandbox

# === Skill System ===
SKILL_AUTO_SUGGEST=true
SKILL_SUGGEST_MIN_OCCURRENCES=5
SKILL_SUGGEST_WINDOW_DAYS=7
SKILL_SUGGEST_MIN_USERS=2
SKILL_DETECT_THRESHOLD=0.75
SKILL_DETECT_MODE=auto

# === Model Context Protocol ===
MCP_ENABLED=true
MCP_RECONNECT_INTERVAL_MS=60000
MCP_TOOL_TIMEOUT_MS=30000

# Token / credentials untuk MCP Server
GITHUB_TOKEN=
