{
  "servers": [
    {
      "name": "filesystem",
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./workspace"
      ],
      "enabled": true,
      "description": "Akses filesystem workspace"
    },
    {
      "name": "openbrowser",
      "type": "stdio",
      "command": "python3",
      "args": [
        "-c",
        "from openbrowser.cli import main; main()",
        "--mcp"
      ],
      "enabled": true,
      "description": "AI-native browser automation server (OpenBrowser)"
    }
  ]
}
